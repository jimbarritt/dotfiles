#!/bin/bash
# Toggle between presentation (light) and normal (dark) mode
# Switches both Ghostty terminal and Neovim colorscheme in one go.
#
# Instead of editing the Ghostty config directly (which would dirty git),
# this creates/removes an overlay file that the main config includes via
# config-file = ?~/.config/ghostty/presentation

set -euo pipefail

PRESENTATION_FILE="$HOME/.config/ghostty/presentation"

DARK_NVIM_COLORSCHEME="green-tinted"
LIGHT_NVIM_COLORSCHEME="green-tinted-light"

ghostty_reload() {
    # Ghostty reloads config on SIGUSR2 (since v1.2.0).
    pkill -USR2 ghostty 2>/dev/null || true
}

tmux_set_theme() {
    local mode="$1"
    if ! tmux info &>/dev/null; then return; fi
    if [ "$mode" = "light" ]; then
        tmux set -g @theme_mode "light"
        tmux set -g status-style "bg=#d8e8d8,fg=#338833"
        tmux set -g message-style "bg=#c0d8c0,fg=#226622"
    else
        tmux set -g @theme_mode ""
        tmux set -g status-style "bg=#122912,fg=#4a7c4a"
        tmux set -g message-style "bg=#1a3a1a,fg=#7ab87a"
    fi
}

nvim_set_colorscheme() {
    local scheme="$1"
    local bg="$2"
    local tmpdir="${TMPDIR:-/tmp}"
    while IFS= read -r -d '' sock; do
        nvim --server "$sock" --remote-send "<Esc>:colorscheme ${scheme}<CR>:set background=${bg}<CR>" 2>/dev/null || true
    done < <(find "$tmpdir" -name 'nvim.*.0' -type s -print0 2>/dev/null)
}

switch_to_light() {
    cat > "$PRESENTATION_FILE" <<'EOF'
# Presentation mode overrides (managed by bin/presentation-mode)
theme = green-tinted-light
background-opacity = 1.0
background-blur-radius = 0
window-theme = light
font-thicken = true
adjust-cell-height = 9
EOF
    ghostty_reload
    tmux_set_theme "light"
    nvim_set_colorscheme "$LIGHT_NVIM_COLORSCHEME" "light"
    echo "Switched to presentation mode (light)"
}

switch_to_dark() {
    rm -f "$PRESENTATION_FILE"
    ghostty_reload
    tmux_set_theme "dark"
    nvim_set_colorscheme "$DARK_NVIM_COLORSCHEME" "dark"
    echo "Switched to normal mode (dark)"
}

if [ -f "$PRESENTATION_FILE" ]; then
    switch_to_dark
else
    switch_to_light
fi
