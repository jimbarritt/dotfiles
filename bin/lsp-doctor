#!/bin/sh
# Diagnose kotlin-lsp state: running processes and workspace lock files.
# Useful for spotting orphaned LSP processes and stale locks.
#
# Usage:
#   lsp-doctor            # list processes and lock files
#   lsp-doctor --clean    # kill orphaned processes and remove stale locks
#   lsp-doctor -h         # show help

LOCK_DIR="${HOME}/.cache/kotlin-lsp-workspaces"
CLEAN=0

case "$1" in
  -h|--help)
    sed -n '2,9p' "$0" | sed 's/^# //; s/^#//'
    exit 0
    ;;
  --clean)
    CLEAN=1
    ;;
  '') ;;
  *)
    printf 'unknown arg: %s\n' "$1" >&2
    exit 1
    ;;
esac

# List orphaned kotlin-lsp processes (ppid=1 means parent has died).
# Format: "PID ETIME"
orphans() {
  ps -eo pid,ppid,etime,comm \
    | awk '$2 == 1 && tolower($0) ~ /kotlin/ {print $1, $3}'
}

# Look up the working directory of a process.
proc_cwd() {
  lsof -a -d cwd -p "$1" 2>/dev/null | awk 'NR>1 {for (i=9;i<=NF;i++) printf "%s%s", $i, (i<NF?" ":""); print ""}'
}

printf '== process tree (nvim + kotlin-lsp) ==\n\n'
# Gather matching processes with their cwd into a tab-separated table.
proc_table=$(
  ps -eo pid,ppid,etime,comm \
    | awk 'tolower($0) ~ /kotlin/ || $4 == "nvim" || $4 ~ /\/nvim$/' \
    | while read -r pid ppid etime comm; do
        cwd=$(proc_cwd "$pid")
        [ -z "$cwd" ] && cwd="(unknown)"
        # Pretty label: collapse JVM path to "kotlin-lsp", distinguish nvim --embed.
        base="${comm##*/}"
        label="$base"
        if [ "$base" = "nvim" ]; then
          full=$(ps -o command= -p "$pid" 2>/dev/null)
          if [ "${full#*--embed}" != "$full" ]; then
            label="nvim --embed"
          else
            label="nvim"
          fi
        elif [ "$base" = "java" ]; then
          label="kotlin-lsp"
        fi
        printf '%s\t%s\t%s\t%s\t%s\n' "$pid" "$ppid" "$etime" "$label" "$cwd"
      done
)

if [ -z "$proc_table" ]; then
  printf '(none)\n'
else
  echo "$proc_table" | awk -F'\t' '
    {
      pid=$1; ppid=$2; etime=$3; label=$4; cwd=$5
      pids[pid] = 1
      parent[pid] = ppid
      etimes[pid] = etime
      labels[pid] = label
      cwds[pid] = cwd
      order[++n] = pid
      if (kids[ppid] == "") kids[ppid] = pid
      else kids[ppid] = kids[ppid] " " pid
    }
    END {
      for (i = 1; i <= n; i++) {
        pid = order[i]
        if (!(parent[pid] in pids)) print_node(pid, "", 1, 1)
      }
    }
    function print_node(pid, prefix, is_last, is_root,    tag, j, ncount, children, branch, new_prefix) {
      tag = ""
      if (parent[pid] == 1) tag = "  [orphan]"
      if (is_root) {
        branch = ""
        new_prefix = ""
      } else if (is_last) {
        branch = "└─ "
        new_prefix = prefix "   "
      } else {
        branch = "├─ "
        new_prefix = prefix "│  "
      }
      printf "%s%s%-14s %-7s %-12s %s%s\n", prefix, branch, labels[pid], pid, "(" etimes[pid] ")", cwds[pid], tag
      ncount = split(kids[pid], children, " ")
      for (j = 1; j <= ncount; j++) {
        print_node(children[j], new_prefix, (j == ncount), 0)
      }
    }
  '
fi

printf '\n== workspace locks (%s) ==\n\n' "$LOCK_DIR"
locks=""
if [ -d "$LOCK_DIR" ]; then
  locks=$(find "$LOCK_DIR" -maxdepth 2 -name '.app.lock' 2>/dev/null)
fi

if [ -z "$locks" ]; then
  printf '(none)\n'
else
  echo "$locks" | while IFS= read -r lock; do
    project=$(basename "$(dirname "$lock")")
    mtime=$(stat -f '%Sm' -t '%Y-%m-%d %H:%M' "$lock" 2>/dev/null \
         || stat -c '%y' "$lock" 2>/dev/null)
    # Match running kotlin-lsp by cwd basename to recover the full path.
    owner_cwd=""
    for pid in $(ps -eo pid,comm | awk 'tolower($0) ~ /kotlin/ {print $1}'); do
      pcwd=$(proc_cwd "$pid")
      if [ "$(basename "$pcwd")" = "$project" ]; then
        owner_cwd="$pcwd"
        break
      fi
    done
    stale=""
    [ -z "$owner_cwd" ] && stale="stale"
    path_col="${owner_cwd:-(no running process)}"
    printf '%-30s  %-18s  %-7s  %s\n' "$project" "$mtime" "$stale" "$path_col"
  done
fi

if [ "$CLEAN" -eq 0 ]; then
  printf '\n(run `lsp-doctor --clean` to kill orphaned processes and remove stale locks)\n'
fi

if [ "$CLEAN" -eq 1 ]; then
  printf '\n== cleaning ==\n\n'

  orph=$(orphans)
  if [ -z "$orph" ]; then
    printf 'no orphaned processes\n'
  else
    echo "$orph" | while read -r pid _; do
      printf 'kill %s\n' "$pid"
      kill "$pid" 2>/dev/null || printf '  (failed)\n'
    done
  fi

  if [ -z "$locks" ]; then
    printf 'no locks to check\n'
  else
    echo "$locks" | while IFS= read -r lock; do
      project=$(basename "$(dirname "$lock")")
      owned=0
      for pid in $(ps -eo pid,comm | awk 'tolower($0) ~ /kotlin/ {print $1}'); do
        if [ "$(basename "$(proc_cwd "$pid")")" = "$project" ]; then
          owned=1
          break
        fi
      done
      if [ "$owned" -eq 0 ]; then
        printf 'rm %s\n' "$lock"
        rm -f "$lock"
      fi
    done
  fi
fi
