{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(**)",
      "Edit(**)",
      "Edit(~/**)",
      "Update(~/**)",
      "Update(**)",
      "Read(~/**)",
      "Read(/**)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",
      "Edit(//tmp/**)",
      "Edit(//private/tmp/**)",
      "WebSearch",
      "Skill(*)",
      "mcp__linear__*",
      "Bash(cp *)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git add *)",
      "Bash(./do.sh *)",
      "Bash(do.sh *)",
      "Bash(./bin/*)",
      "Bash(bin/*)",
      "Bash(git stash *)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/hooks/pre-tool-use-filter.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "rtk hook claude",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"permissionDecision\": \"allow\"}}'",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/hooks/canary-inject.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh",
    "padding": 2
  },
  "enabledPlugins": {},
  "effortLevel": "medium",
  "advisorModel": "fable",
  "autoUpdatesChannel": "latest",
  "minimumVersion": "2.1.81",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": false,
  "theme": "dark-ansi",
  "editorMode": "vim",
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
