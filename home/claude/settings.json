{
  "agentPushNotifEnabled": true,
  "autoUpdatesChannel": "latest",
  "editorMode": "vim",
  "effortLevel": "high",
  "enabledPlugins": {},
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "rtk hook claude",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"permissionDecision\": \"allow\"}}'",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "WebFetch"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "sh ~/.claude/hooks/canary-inject.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "minimumVersion": "2.1.81",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Write(~/**)",
      "Edit(~/**)",
      "Update(~/**)",
      "Update(**)",
      "Read(~/**)",
      "Read(/**)",
      "WebSearch",
      "Skill(*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git add:*)",
      "Bash(./do.sh:*)",
      "Bash(do.sh:*)",
      "Bash(./bin/:*)",
      "Bash(bin/:*)",
      "Bash(git stash:*)"
    ]
  },
  "skipDangerousModePermissionPrompt": false,
  "statusLine": {
    "command": "sh ~/.claude/statusline-command.sh",
    "padding": 2,
    "type": "command"
  },
  "theme": "dark-ansi",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "voiceEnabled": true
}