# Font
font-family = Monaspace Neon
font-size = 16
adjust-cell-height = 5

# Cursor
cursor-style = block
cursor-style-blink = true

# Window
window-padding-x = 10
window-padding-y = 10
macos-titlebar-style = hidden

# Shell
shell-integration = detect
shell-integration-features = no-cursor

# Theme
theme = green-tinted
background-opacity = 0.92
background-blur-radius = 40

# Bell
bell-features = no-audio,no-system,no-title,no-attention,no-border

# Tabs
window-show-tab-bar = always

# macOS
macos-option-as-alt = false

# UK keyboard: alt+3 sends # instead of £
keybind = alt+3=text:#

# Optional overlay for presentation mode (created/removed by bin/presentation-mode)
config-file = ?~/.config/ghostty/presentation
